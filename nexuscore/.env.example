PORT=5000
WEB_PORT=5173
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=nexuscore
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=1d
FREE_CLOUD_SLOTS=3

# --- Remote access (Tailscale / LAN / tunnel) ---
# Use start-site-network.bat (HTTP) or start-site-https.bat (HTTPS via Tailscale Serve)
# Split agent on another PC (3 laptops): set PUBLIC_* to URLs reachable from that PC

# Bind API on all interfaces when NETWORK_MODE=1 (set by start-site-network.bat)
# API_BIND=0.0.0.0
# NETWORK_MODE=1

# HTTPS via Tailscale Serve (set automatically by start-site-https.bat)
# HTTPS_MODE=1

# Public URLs — required for cloud agent on another machine/network.
# Examples:
#   Tailscale HTTP:  PUBLIC_WEB_URL=http://100.x.x.x:5173
#   Tailscale HTTPS: PUBLIC_WEB_URL=https://your-pc.tail1234.ts.net  (use start-site-https.bat)
#   ngrok:           PUBLIC_API_URL=https://abc.ngrok-free.app/api
#   LAN test:        leave empty — start-site-network.bat auto-detects your IP
PUBLIC_API_URL=
PUBLIC_WEB_URL=
