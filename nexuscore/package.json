{
  "name": "NexusCore",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "node setup.js && npm install --no-fund --no-audit && npm run install:all",
    "install:all": "cd client && npm install",
    "seed": "node seed.js",
    "server": "dotnet run --project NexusCore.Api --no-launch-profile --urls http://localhost:5000",
    "client": "cd client && npm run dev",
    "dev": "concurrently -k -n api,web -c blue,green \"npm run server\" \"npm run client\"",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "mysql2": "^3.9.7"
  }
}
