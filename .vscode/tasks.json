{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "NexusCore: Start All",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File start.ps1",
      "options": { "cwd": "${workspaceFolder}/nexuscore" },
      "group": { "kind": "build", "isDefault": true },
      "isBackground": true,
      "problemMatcher": {
        "owner": "nexuscore",
        "pattern": { "regexp": "^.*$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+http://localhost:5173"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    }
  ]
}
