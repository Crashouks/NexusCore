# Browser API path — keep /api when using Vite (works for remote players too)
VITE_API_URL=/api

# Full URLs for cloud agent config + admin setup (another PC / network)
# Set in nexuscore/.env as PUBLIC_API_URL / PUBLIC_WEB_URL — synced by start-site-network.bat
# Example: VITE_PUBLIC_API_URL=http://100.64.1.5:5000/api
VITE_PUBLIC_API_URL=
VITE_PUBLIC_WEB_URL=

# Set automatically in network mode
# VITE_DEV_HOST=0.0.0.0
