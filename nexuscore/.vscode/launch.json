{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NexusCore API (Swagger)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/NexusVault.Api/bin/Debug/net10.0/NexusCore.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/NexusVault.Api",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "SpaProxyLaunchManager",
        "uriFormat": "http://localhost:5173"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_HOSTINGSTARTUPASSEMBLIES": "Microsoft.AspNetCore.SpaProxy"
      }
    }
  ]
}
